#!/usr/bin/env bash
#
# silverblue-update — atomic, snapshot-based, auto-rolling-back updates for Arch Silverblue.
#
# Each run snapshots the running Btrfs root into a new subvolume root-YYYYMMDD-HHMMSS,
# upgrades that snapshot with pacman inside an arch-chroot, validates it, registers it as a
# new bootloader entry, and arranges for it to boot NEXT without disturbing the permanent
# default. A post-boot service (silverblue-mark-good) later promotes it to default on
# success, or the bootloader auto-reverts to the previous snapshot on failure.
#
# The running system stays fully mutable: atomicity comes only from Btrfs copy-on-write
# snapshots, never from read-only mounts.
#
# The script is self-contained and sourceable: when sourced (BASH_SOURCE != $0) it only
# defines functions, so unit tests can exercise the pure logic with mocked command paths.

# --- Dependency-injected command paths (override in tests / unusual layouts) ---------------
: "${BTRFS:=btrfs}"
: "${BOOTCTL:=bootctl}"
: "${GRUB_EDITENV:=grub-editenv}"
: "${ARCH_CHROOT:=arch-chroot}"
: "${FINDMNT:=findmnt}"
: "${MOUNT:=mount}"
: "${UMOUNT:=umount}"

# --- Configuration (override via environment) ----------------------------------------------
: "${SB_EFI_DIR:=/efi}"                       # ESP mount point
: "${SB_TOPLEVEL_MNT:=/run/silverblue/toplevel}"  # where Btrfs subvolid=5 is mounted
: "${SB_KEEP:=3}"                             # max snapshots to retain
: "${SB_TRIES:=3}"                            # systemd-boot boot-counting tries
: "${SB_LIB_DIR:=}"                           # dir containing *-helpers.sh (auto-detected)
: "${SB_VERIFY_UNIT:=/usr/lib/systemd/system/silverblue-mark-good.service}"
: "${SB_DISTRO_NAME:=Arch Silverblue}"        # human-readable name used in boot-entry titles
: "${SB_ESP_SUBDIR:=silverblue}"              # per-snapshot kernel dir on the ESP (systemd-boot)
: "${SB_SORT_KEY:=silverblue}"                # systemd-boot 'sort-key' grouping value

# --- Runtime state (populated at run time) -------------------------------------------------
DRY_RUN=false
VERBOSE=false
DO_ROLLBACK=false
DO_VERIFY=false
VERIFY_TARGET=""
DO_GEN_MANIFEST=""
BOOTLOADER=""
SB_ROOT_DEV=""
SB_POOL_UUID=""
CURRENT_SUBVOL=""
SB_KERNEL_OPTS=""
NEW_SNAP=""
UPDATE_COMMITTED=0
TOPLEVEL_WE_MOUNTED=0

# --- Logging & execution guards ------------------------------------------------------------
log()  { printf '%s\n' "$*" >&2; }
err()  { printf 'error: %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }
vlog() { if $VERBOSE; then printf '%s\n' "$*" >&2; fi; }

# Run a state-changing command, honoring --dry-run. Named sb_run (not run) so the engine can
# be sourced into bats unit tests without clobbering bats's own run() helper.
sb_run() {
    if $DRY_RUN; then log "DRY: $*"; return 0; fi
    vlog "+ $*"
    "$@"
}

# Write stdin to a file, honoring --dry-run.
emit_file() {
    local path=$1
    if $DRY_RUN; then
        log "DRY: write $path"
        cat >/dev/null
    else
        vlog "+ write $path"
        cat >"$path"
    fi
}

# --- Locate and source the bootloader helper libraries -------------------------------------
resolve_lib_dir() {
    local self_dir d
    self_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
    for d in "$SB_LIB_DIR" "$self_dir" "$self_dir/../bootloader" /usr/lib/silverblue; do
        [[ -n "$d" && -f "$d/sdboot-helpers.sh" && -f "$d/grub-helpers.sh" ]] && {
            printf '%s\n' "$d"
            return 0
        }
    done
    return 1
}

if _libdir=$(resolve_lib_dir); then
    SB_LIB_DIR=$_libdir
    # shellcheck source=/dev/null
    source "$SB_LIB_DIR/sdboot-helpers.sh"
    # shellcheck source=/dev/null
    source "$SB_LIB_DIR/grub-helpers.sh"
    unset _libdir
fi

# Init-system backends (root init detection for validate_root; health/reboot dispatch for the
# scripts that source this engine). Optional: validate_root falls back to systemd behavior.
resolve_init_lib() {
    local self_dir d
    self_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
    for d in "$SB_LIB_DIR" "$self_dir" "$self_dir/../init" /usr/lib/silverblue; do
        [[ -n "$d" && -f "$d/init-backends.sh" ]] && { printf '%s\n' "$d/init-backends.sh"; return 0; }
    done
    return 1
}

if _initlib=$(resolve_init_lib); then
    # shellcheck source=/dev/null
    source "$_initlib"
    unset _initlib
fi

# Integrity manifests (HMAC-signed checksums of each snapshot's OS payload). Optional: the
# engine warns and continues when absent, so a partial install degrades instead of breaking.
resolve_integrity_lib() {
    local self_dir d
    self_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
    for d in "$SB_LIB_DIR" "$self_dir" /usr/lib/silverblue; do
        [[ -n "$d" && -f "$d/integrity.sh" ]] && { printf '%s\n' "$d/integrity.sh"; return 0; }
    done
    return 1
}

if _intlib=$(resolve_integrity_lib); then
    # shellcheck source=/dev/null
    source "$_intlib"
    unset _intlib
fi

# ============================== Pure functions (unit-tested) ===============================

# Current timestamp (override with SB_NOW for deterministic tests).
now_ts() {
    if [[ -n "${SB_NOW:-}" ]]; then printf '%s\n' "$SB_NOW"; else date +%Y%m%d-%H%M%S; fi
}

# Name for a fresh snapshot, e.g. root-20260628-093000.
next_snapshot_name() {
    printf 'root-%s\n' "$(now_ts)"
}

# Human-readable bootloader label for a snapshot, e.g. "Arch Silverblue 2026-06-28 09:30".
label_for() {
    local snap=$1 ts d t
    ts=${snap#root-}
    d=${ts%%-*}
    t=${ts#*-}
    printf '%s %s-%s-%s %s:%s\n' "$SB_DISTRO_NAME" \
        "${d:0:4}" "${d:4:2}" "${d:6:2}" "${t:0:2}" "${t:2:2}"
}

# Extract the booted subvolume from a kernel command line (defaults to /proc/cmdline).
parse_subvol_from_cmdline() {
    local cmdline=${1:-} tok val
    [[ -n "$cmdline" ]] || cmdline=$(cat /proc/cmdline 2>/dev/null || true)
    for tok in $cmdline; do
        case "$tok" in
            rootflags=*subvol=*)
                val=${tok##*subvol=}
                val=${val%%,*}
                printf '%s\n' "$val"
                return 0
                ;;
        esac
    done
    return 1
}

# Extra kernel command-line options to carry over to a new entry: everything on the current
# /proc/cmdline except the root/subvol/initrd bits the engine sets itself (and archiso noise).
# This preserves things like console=, quiet, etc. so a new root boots like the current one.
kernel_extra_opts() {
    local cmdline=${1:-} tok out=""
    [[ -n "$cmdline" ]] || cmdline=$(cat /proc/cmdline 2>/dev/null || true)
    for tok in $cmdline; do
        case "$tok" in
            BOOT_IMAGE=*|initrd=*|root=*|rootflags=*|rootfstype=*|ro|rw) continue ;;
            archisobasedir=*|archisosearchuuid=*|archisolabel=*|cow_spacesize=*|copytoram*) continue ;;
            *) out="$out $tok" ;;
        esac
    done
    printf '%s\n' "${out# }"
}

# List root-* snapshots in a directory (default: the toplevel mount), sorted oldest-first.
list_snapshots() {
    local mnt=${1:-$SB_TOPLEVEL_MNT} name
    [[ -d "$mnt" ]] || return 0
    for name in "$mnt"/root-*; do
        [[ -d "$name" ]] || continue
        printf '%s\n' "${name##*/}"
    done | sort
}

# Given an oldest-first list on stdin and a keep count ($1), print the snapshots to delete.
prune_plan() {
    local keep=$1 lines total del
    mapfile -t lines
    total=${#lines[@]}
    del=$(( total - keep ))
    (( del > 0 )) || return 0
    printf '%s\n' "${lines[@]:0:del}"
}

# Print the bootloader in use under an ESP dir ($1): "systemd-boot" or "grub".
detect_bootloader() {
    local efi=${1:-$SB_EFI_DIR}
    if sdboot_is_active "$efi"; then printf 'systemd-boot\n'; return 0; fi
    if grub_is_active "$efi"; then printf 'grub\n'; return 0; fi
    return 1
}

# ============================== Effectful operations =======================================

detect_root_storage() {
    local raw
    if [[ -z "$SB_ROOT_DEV" ]]; then
        raw=$("$FINDMNT" -no SOURCE -T / 2>/dev/null || true)
        SB_ROOT_DEV=${raw%%[*}
    fi
    [[ -n "$SB_POOL_UUID" ]] || SB_POOL_UUID=$("$FINDMNT" -no UUID -T / 2>/dev/null || true)
}

get_current_subvol() {
    local sv
    sv=$(parse_subvol_from_cmdline 2>/dev/null) || sv=""
    if [[ -z "$sv" ]]; then
        sv=$("$FINDMNT" -no FSROOT -T / 2>/dev/null || true)
        sv=${sv#/}
    fi
    printf '%s\n' "$sv"
}

load_runtime() {
    BOOTLOADER=${SB_BOOTLOADER:-$(detect_bootloader "$SB_EFI_DIR" 2>/dev/null || true)}
    detect_root_storage
    CURRENT_SUBVOL=$(get_current_subvol 2>/dev/null || true)
    SB_KERNEL_OPTS=${SB_KERNEL_OPTS:-$(kernel_extra_opts)}

    if [[ -z "$BOOTLOADER" ]]; then
        if $DRY_RUN; then
            BOOTLOADER=systemd-boot
            log "note: bootloader not detected under $SB_EFI_DIR; assuming systemd-boot (dry-run)"
        else
            die "could not detect bootloader under $SB_EFI_DIR (need systemd-boot or grub)"
        fi
    fi
    if [[ -z "$CURRENT_SUBVOL" && $DRY_RUN == true ]]; then
        CURRENT_SUBVOL="root-current"
    fi
    vlog "bootloader=$BOOTLOADER dev=$SB_ROOT_DEV uuid=$SB_POOL_UUID current=$CURRENT_SUBVOL"
}

ensure_prereqs() {
    $DRY_RUN && return 0
    [[ ${EUID:-$(id -u)} -eq 0 ]] || die "must run as root"
    command -v "$BTRFS" >/dev/null 2>&1 || die "btrfs not found (install btrfs-progs)"
    [[ "$("$FINDMNT" -no FSTYPE -T / 2>/dev/null)" == btrfs ]] || die "root filesystem is not Btrfs"
    [[ -n "$SB_ROOT_DEV" ]] || die "could not determine root device"
    [[ -n "$SB_POOL_UUID" ]] || die "could not determine Btrfs pool UUID"
}

ensure_toplevel_mounted() {
    sb_run mkdir -p "$SB_TOPLEVEL_MNT"
    if $DRY_RUN; then return 0; fi
    if ! mountpoint -q "$SB_TOPLEVEL_MNT"; then
        sb_run "$MOUNT" -o subvolid=5 "$SB_ROOT_DEV" "$SB_TOPLEVEL_MNT"
        TOPLEVEL_WE_MOUNTED=1
    fi
}

cleanup_toplevel() {
    [[ "$TOPLEVEL_WE_MOUNTED" == 1 ]] || return 0
    sb_run "$UMOUNT" "$SB_TOPLEVEL_MNT" || true
    TOPLEVEL_WE_MOUNTED=0
}

create_snapshot() {
    local snap=$1
    sb_run "$BTRFS" subvolume snapshot / "$SB_TOPLEVEL_MNT/$snap"
}

chroot_upgrade() {
    local root=$1
    local conf="$root/etc/pacman.conf"
    # pacman returns non-zero on any download/package error; set -e + the EXIT trap then
    # discard the half-built snapshot, so no partial snapshot is ever left behind.
    #
    # Inside an arch-chroot on a snapshot mounted at a deep path, pacman cannot resolve the
    # cachedir's mountpoint, which breaks both its free-space check (CheckSpace) and its
    # downloader sandbox. Disable CheckSpace for the upgrade (restored afterwards) and pass
    # --disable-sandbox. The snapshot/atomic model makes the pre-check redundant anyway.
    if [[ -f "$conf" ]]; then
        sb_run sed -i 's/^[[:space:]]*CheckSpace/#CheckSpace/' "$conf"
    fi
    sb_run "$ARCH_CHROOT" "$root" pacman -Syu --noconfirm --disable-sandbox
    if [[ -f "$conf" ]]; then
        sb_run sed -i 's/^#CheckSpace/CheckSpace/' "$conf"
    fi
}

validate_root() {
    local root=$1
    local boot="$root/boot"
    if $DRY_RUN; then
        log "DRY: validate $boot (>=1 kernel, >=1 initramfs, unit verify)"
        return 0
    fi
    shopt -s nullglob
    local kernels=("$boot"/vmlinuz-*) initrds=("$boot"/initramfs-*.img)
    shopt -u nullglob
    (( ${#kernels[@]} > 0 )) || { err "no kernel image under $boot"; return 1; }
    (( ${#initrds[@]} > 0 )) || { err "no initramfs under $boot"; return 1; }
    vlog "found kernels: ${kernels[*]##*/}"
    vlog "found initramfs: ${initrds[*]##*/}"
    # Unit verification is init-specific; probe the new root (not the running system) so a
    # derivative's openrc/dinit snapshot is not pushed through systemd-analyze.
    local root_init=systemd
    if declare -F detect_root_init >/dev/null; then
        root_init=$(detect_root_init "$root")
    fi
    case "$root_init" in
        systemd)
            if [[ -e "$root$SB_VERIFY_UNIT" ]]; then
                if ! sb_run "$ARCH_CHROOT" "$root" systemd-analyze verify "$SB_VERIFY_UNIT"; then
                    err "systemd-analyze verify reported errors for $SB_VERIFY_UNIT"
                    return 1
                fi
            else
                vlog "skipping systemd-analyze verify ($SB_VERIFY_UNIT absent in new root)"
            fi
            ;;
        dinit)
            if [[ -x "$root/usr/bin/dinitcheck" ]]; then
                if ! sb_run "$ARCH_CHROOT" "$root" dinitcheck; then
                    err "dinitcheck reported errors in the new root"
                    return 1
                fi
            else
                vlog "skipping dinitcheck (not present in new root)"
            fi
            ;;
        *)
            vlog "skipping unit verification (init=$root_init)"
            ;;
    esac
}

register_entry() {
    local snap=$1 label=$2
    if $DRY_RUN; then
        log "DRY: register $BOOTLOADER boot entry for $snap (\"$label\")"
        return 0
    fi
    case "$BOOTLOADER" in
        systemd-boot)
            sdboot_register_entry "$snap" "$label" "$SB_POOL_UUID" \
                "$SB_TOPLEVEL_MNT/$snap/boot" "$SB_EFI_DIR" "$SB_TRIES"
            ;;
        grub)
            grub_regen_all
            ;;
        *) die "unsupported bootloader: $BOOTLOADER" ;;
    esac
}

grub_regen_all() {
    local pairs=() snap
    while IFS= read -r snap; do
        [[ -n "$snap" ]] || continue
        pairs+=("$snap|$(label_for "$snap")")
    done < <(list_snapshots)
    grub_regen_cfg "$SB_EFI_DIR" "$SB_POOL_UUID" "${pairs[@]}"
}

set_next_boot() {
    local snap=$1
    case "$BOOTLOADER" in
        systemd-boot) sdboot_set_next "$snap" ;;
        grub)         grub_set_next "$snap" "$SB_EFI_DIR" ;;
        *) die "unsupported bootloader: $BOOTLOADER" ;;
    esac
}

prune_boot_entry() {
    local snap=$1
    case "$BOOTLOADER" in
        systemd-boot) sdboot_prune_entry "$snap" "$SB_EFI_DIR" ;;
        grub)         grub_prune_entry "$snap" "$SB_EFI_DIR" ;;
    esac
}

prune_snapshots() {
    local victims=() snap
    mapfile -t victims < <(list_snapshots | prune_plan "$SB_KEEP")
    for snap in "${victims[@]}"; do
        [[ -n "$snap" ]] || continue
        if [[ "$snap" == "$CURRENT_SUBVOL" ]]; then
            vlog "keeping running root $snap"
            continue
        fi
        log "    pruning $snap"
        prune_boot_entry "$snap"
        discard_snapshot "$snap"
    done
    [[ "$BOOTLOADER" == grub ]] && grub_regen_all
    return 0
}

discard_snapshot() {
    local snap=$1 path
    [[ -n "$snap" ]] || return 0
    path="$SB_TOPLEVEL_MNT/$snap"
    if [[ -d "$path" ]]; then
        sb_run "$BTRFS" subvolume delete "$path" || log "warn: could not delete subvolume $path"
    fi
    # A discarded snapshot's integrity manifest must go with it (covers pruning, the EXIT
    # trap's half-built-snapshot cleanup, and every future caller).
    if declare -F delete_manifest >/dev/null; then
        delete_manifest "$snap"
    fi
}

# Newest snapshot that is not the currently running root.
previous_snapshot() {
    local snap prev=""
    while IFS= read -r snap; do
        [[ "$snap" == "$CURRENT_SUBVOL" ]] && continue
        prev=$snap
    done < <(list_snapshots)
    [[ -n "$prev" ]] && printf '%s\n' "$prev"
}

# All non-current snapshots, newest first (rollback candidates in preference order).
previous_snapshots() {
    local snap out=()
    while IFS= read -r snap; do
        [[ "$snap" == "$CURRENT_SUBVOL" ]] && continue
        out=("$snap" "${out[@]}")
    done < <(list_snapshots)
    (( ${#out[@]} )) && printf '%s\n' "${out[@]}"
}

# Apply the SB_VERIFY_ON_ROLLBACK policy to a rollback candidate: print the snapshot to roll
# back into (stdout), or fail. Policies:
#   off     no verification.
#   warn    (default) verify the candidate; on mismatch log SILVERBLUE-VERIFY-WARN loudly and
#           proceed anyway — on the unattended OnFailure path, refusing to roll back would
#           turn one bad update into a boot loop.
#   strict  newest-first, the first candidate that verifies wins; a manifest-less snapshot
#           (pre-feature) is accepted with a note, a failed one is skipped. Nothing left ->
#           fail WITHOUT arming a rollback (the caller dies; rollback.sh then holds the
#           machine in emergency instead of rebooting).
verified_rollback_target() {
    local prev=$1 cand rc
    if [[ "${SB_VERIFY_ON_ROLLBACK:-warn}" == off ]] || ! declare -F verify_manifest >/dev/null; then
        printf '%s\n' "$prev"
        return 0
    fi
    if $DRY_RUN; then
        log "DRY: verify integrity manifest of $prev (policy: ${SB_VERIFY_ON_ROLLBACK:-warn})"
        printf '%s\n' "$prev"
        return 0
    fi
    if [[ "${SB_VERIFY_ON_ROLLBACK:-warn}" != strict ]]; then
        rc=0; verify_manifest "$prev" || rc=$?
        if (( rc == 1 )); then
            log "SILVERBLUE-VERIFY-WARN snap=$prev"
            err "warning: rolling back into $prev despite failed integrity verification (SB_VERIFY_ON_ROLLBACK=warn)"
        fi
        printf '%s\n' "$prev"
        return 0
    fi
    while IFS= read -r cand; do
        rc=0; verify_manifest "$cand" || rc=$?
        case $rc in
            0) printf '%s\n' "$cand"; return 0 ;;
            2) log "note: $cand predates integrity manifests; accepting"
               printf '%s\n' "$cand"; return 0 ;;
            *) err "skipping rollback candidate $cand (failed integrity verification)" ;;
        esac
    done < <(previous_snapshots)
    err "no snapshot passed integrity verification (SB_VERIFY_ON_ROLLBACK=strict)"
    return 1
}

# ============================== Top-level flows ============================================

do_update() {
    local label
    ensure_prereqs
    NEW_SNAP=$(next_snapshot_name)
    label=$(label_for "$NEW_SNAP")

    log "==> Atomic update plan"
    log "    bootloader : $BOOTLOADER"
    log "    current    : ${CURRENT_SUBVOL:-<unknown>}"
    log "    new root   : $NEW_SNAP"
    log "    label      : $label"
    log "    keep       : $SB_KEEP snapshots"

    ensure_toplevel_mounted
    log "==> [1/7] Snapshot running root -> $NEW_SNAP"
    create_snapshot "$NEW_SNAP"
    log "==> [2/7] Upgrade packages in new root (pacman -Syu)"
    chroot_upgrade "$SB_TOPLEVEL_MNT/$NEW_SNAP"
    log "==> [3/7] Validate new root (kernel, initramfs, unit verify)"
    validate_root "$SB_TOPLEVEL_MNT/$NEW_SNAP"
    log "==> [4/7] Register boot entry"
    register_entry "$NEW_SNAP" "$label"
    # After register_entry so the systemd-boot ESP copies exist and get recorded too.
    log "==> [5/7] Write integrity manifest (HMAC-signed)"
    if declare -F generate_manifest >/dev/null; then
        generate_manifest "$NEW_SNAP"
    else
        log "warn: integrity library not found; skipping manifest"
    fi
    log "==> [6/7] Make it the next boot (permanent default unchanged)"
    case "$BOOTLOADER" in
        grub)         set_next_boot "$NEW_SNAP" ;;
        systemd-boot) vlog "systemd-boot: newest version '$NEW_SNAP' boots next automatically" ;;
    esac
    log "==> [7/7] Prune snapshots beyond $SB_KEEP"
    prune_snapshots

    UPDATE_COMMITTED=1
    cleanup_toplevel
    log "==> Done. Reboot to apply: $label"
}

do_rollback() {
    local prev
    ensure_prereqs
    ensure_toplevel_mounted
    prev=$(previous_snapshot) || true
    if [[ -z "$prev" ]]; then
        if $DRY_RUN; then
            prev="root-previous"
            log "note: no snapshots visible; using placeholder $prev (dry-run)"
        else
            die "no previous snapshot available to roll back to"
        fi
    fi
    prev=$(verified_rollback_target "$prev") || die "rollback aborted: no snapshot passed integrity verification"
    log "==> Rollback: next boot -> $prev ($(label_for "$prev"))"
    set_next_boot "$prev"
    UPDATE_COMMITTED=1
    cleanup_toplevel
    log "==> Done. Reboot to roll back into $prev"
}

# Verify integrity manifests: the named snapshot, or every snapshot that is not the running
# root. Exits non-zero if any verification fails (an absent manifest is reported, not fatal).
do_verify() {
    local snap targets=() rc=0 vrc
    declare -F verify_manifest >/dev/null || die "integrity library not available"
    ensure_prereqs
    ensure_toplevel_mounted
    if [[ -n "$VERIFY_TARGET" ]]; then
        targets=("$VERIFY_TARGET")
    else
        while IFS= read -r snap; do
            [[ "$snap" == "$CURRENT_SUBVOL" ]] && continue
            targets+=("$snap")
        done < <(list_snapshots)
    fi
    (( ${#targets[@]} > 0 )) || die "no snapshots to verify under $SB_TOPLEVEL_MNT"
    for snap in "${targets[@]}"; do
        if [[ "$snap" == "$CURRENT_SUBVOL" ]]; then
            log "note: $snap is the running root — a live root is mutable by design, so a"
            log "      mismatch may reflect legitimate local changes (e.g. manual pacman use)"
        fi
        vrc=0; verify_manifest "$snap" || vrc=$?
        (( vrc == 1 )) && rc=1
    done
    cleanup_toplevel
    return "$rc"
}

# (Re)write the integrity manifest for one snapshot. Used by the installer for the initial
# root (the live ISO's / is not Btrfs, so ensure_prereqs does not apply here; the installer
# pre-mounts the toplevel and passes SB_TOPLEVEL_MNT/SB_EFI_DIR/SB_BOOTLOADER); also useful
# to re-stamp a snapshot after intentional manual changes.
do_generate_manifest() {
    local snap=$1
    declare -F generate_manifest >/dev/null || die "integrity library not available"
    if ! $DRY_RUN; then
        [[ ${EUID:-$(id -u)} -eq 0 ]] || die "must run as root"
    fi
    ensure_toplevel_mounted
    log "==> Generate integrity manifest for $snap"
    generate_manifest "$snap"
    cleanup_toplevel
    log "==> Done."
}

# ============================== Entry point ===============================================

usage() {
    cat <<'EOF'
Usage: silverblue-update [--dry-run] [--verbose] [--rollback]
                         [--verify [SNAPSHOT]] [--generate-manifest SNAPSHOT]

  (no args)    Snapshot the running root, upgrade it, validate it, write its integrity
               manifest, and register it as the next boot target without changing the
               permanent default.
  --rollback   Set the previous snapshot as the next boot target (manual rollback). The
               target's integrity manifest is checked first; SB_VERIFY_ON_ROLLBACK
               (warn|strict|off, default warn) controls what a mismatch does.
  --verify [SNAPSHOT]
               Verify integrity manifests: the named snapshot, or every snapshot that is
               not the running root. Verifying the running root is advisory only — a live
               root is mutable by design. Exits non-zero if any verification fails.
  --generate-manifest SNAPSHOT
               (Re)write the integrity manifest for SNAPSHOT. Used by the installer for
               the initial root; also re-stamps a snapshot after intentional manual
               changes (e.g. pacman run outside the update engine).
  --dry-run    Print the planned steps without making any changes.
  --verbose    Verbose output (echo each privileged command).
  -h, --help   Show this help and exit.
EOF
}

parse_args() {
    while (( $# )); do
        case "$1" in
            --dry-run)     DRY_RUN=true ;;
            --verbose|-v)  VERBOSE=true ;;
            --rollback)    DO_ROLLBACK=true ;;
            --verify)
                DO_VERIFY=true
                if [[ "${2:-}" == root-* ]]; then
                    VERIFY_TARGET=$2
                    shift
                fi
                ;;
            --generate-manifest)
                [[ -n "${2:-}" ]] || die "--generate-manifest needs a snapshot name"
                DO_GEN_MANIFEST=$2
                shift
                ;;
            -h|--help)     usage; exit 0 ;;
            *)             die "unknown argument: $1 (try --help)" ;;
        esac
        shift
    done
}

on_exit() {
    local rc=$?
    if (( rc != 0 )) && [[ -n "$NEW_SNAP" && "$UPDATE_COMMITTED" != 1 ]]; then
        err "update failed (rc=$rc); discarding snapshot $NEW_SNAP"
        discard_snapshot "$NEW_SNAP" || true
    fi
    cleanup_toplevel || true
    exit "$rc"
}

main() {
    parse_args "$@"
    trap on_exit EXIT
    load_runtime
    if [[ -n "$DO_GEN_MANIFEST" ]]; then
        do_generate_manifest "$DO_GEN_MANIFEST"
    elif $DO_VERIFY; then
        do_verify
    elif $DO_ROLLBACK; then
        do_rollback
    else
        do_update
    fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    set -euo pipefail
    main "$@"
fi
